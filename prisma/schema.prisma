generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. USER & GROWTH (The "Account" Layer)
// ==========================================

model User {
  id       String       @id @default(cuid())
  platform UserPlatform
  fid      Int?         @unique
  username String?      @db.VarChar(100)
  pfpUrl   String?      @db.VarChar(500)
  wallet   String?      @unique @db.VarChar(42)

  // -- ADMIN --
  role     UserRole @default(USER)
  password String?

  // -- REFERRAL (who brought them into the system) --
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id])
  referredById String?
  referrals    User[]  @relation("Referrals")

  // -- INVITE SYSTEM --
  inviteCode    String       @unique @db.VarChar(25)
  inviteQuota   Int          @default(3) @db.SmallInt
  redeemedCodes InviteCode[]

  // -- ACCESS CONTROL --
  hasGameAccess   Boolean   @default(false)
  accessGrantedAt DateTime?
  accessGrantedBy String?
  onboardingCompletedAt DateTime?

  // -- v2 PROGRESSION / ECONOMY --
  xp            Int       @default(0)
  ticketBalance Int       @default(3) // off-chain soft-currency balance (1 ticket = 0.1 USDT peg)
  lives         Int       @default(5) @db.SmallInt
  nextLifeAt    DateTime?
  streakFreezes Int       @default(0) @db.SmallInt
  avatarId      String?   @db.VarChar(40)

  // -- STREAKS --
  currentStreak Int       @default(0)
  bestStreak    Int       @default(0)
  lastLoginAt   DateTime?

  // -- BAN --
  isBanned Boolean   @default(false)
  bannedAt DateTime?
  bannedBy String?

  // -- QUEST TRACKING --
  completedQuests  CompletedQuest[]

  // -- REWARD TRACKING --
  rewards ReferralReward[] @relation("InviterRewards")

  // -- TIMESTAMPS --
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // -- RELATIONS --
  entries   GameEntry[]
  notifs    NotificationToken[]
  auditLogs AuditLog[]
  wallets   UserWallet[]
  pendingPurchases PendingPurchase[]

  // -- v2 MIGRATION RELATIONS --
  ticketLedger      TicketLedger[]
  levelProgress     LevelProgress[]
  roundEntries      RoundEntry[]
  announcementState AnnouncementState[]
  questProgress     QuestProgress[]
  leagueMembers     LeagueMember[]
  purchases         Purchase[]
  powerUps          PowerUpInventory[]
  cosmetics         UserCosmetic[]
  boosts            UserBoost[]
  earnedBadges      UserBadge[]
  dailyClaims       DailyRewardClaim[]
  partnerClaims     PartnerOfferClaim[]
  seasonPassClaims  SeasonPassClaim[]
  analyticsEvents   AnalyticsEvent[]
}

enum UserRole {
  USER
  ADMIN
}

enum UserPlatform {
  FARCASTER
  MINIPAY
  BASE_APP
}

model UserWallet {
  id        String       @id @default(cuid())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  wallet    String       @unique @db.VarChar(42)
  platform  UserPlatform
  createdAt DateTime     @default(now())
  lastUsedAt DateTime?

  @@index([userId])
  @@index([platform, wallet])
}

enum PendingPurchaseStatus {
  SUBMITTED
  SYNCED
  FAILED
}

enum GameNetwork {
  BASE_MAINNET
  BASE_SEPOLIA
  CELO_MAINNET
  CELO_SEPOLIA
}

model ReferralReward {
  id        String @id @default(cuid())
  inviter   User   @relation("InviterRewards", fields: [inviterId], references: [id])
  inviterId String

  inviteeId String @unique

  status RewardStatus @default(PENDING)
  amount Int          @default(0) @db.SmallInt

  createdAt  DateTime  @default(now())
  unlockedAt DateTime?

  @@index([inviterId])
}

enum RewardStatus {
  PENDING
  UNLOCKED
  CLAIMED
}

// ==========================================
// 1.5 QUEST SYSTEM
// ==========================================

enum QuestType {
  LINK
  FARCASTER_FOLLOW
  FARCASTER_CAST
  FARCASTER_RECAST
  REFERRAL
  CUSTOM
}

enum QuestCategory {
  SOCIAL
  ONBOARDING
  REFERRAL
  ENGAGEMENT
  SPECIAL
}

enum RepeatFrequency {
  ONCE
  DAILY
  WEEKLY
  UNLIMITED
}

model Quest {
  id   String @id @default(cuid())
  slug String @unique @db.VarChar(50)

  // -- DISPLAY --
  title       String  @db.VarChar(100)
  description String  @db.VarChar(500)
  iconUrl     String? @db.VarChar(255)

  // -- CATEGORIZATION --
  category  QuestCategory @default(SOCIAL)
  sortOrder Int           @default(0) @db.SmallInt

  // -- REWARDS --
  points Int @default(0) @db.SmallInt

  // -- ACTION CONFIG --
  type      QuestType
  actionUrl String?   @db.VarChar(500)
  castHash  String?   @db.VarChar(66)
  targetFid Int?

  // -- REQUIREMENTS --
  requiredCount Int @default(1) @db.SmallInt

  // -- SCHEDULING --
  isActive Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?

  // -- REPEATABILITY --
  repeatFrequency RepeatFrequency @default(ONCE)

  // -- TIMESTAMPS --
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // -- RELATIONS --
  completions CompletedQuest[]
  progress    QuestProgress[]
}

model CompletedQuest {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  quest   Quest  @relation(fields: [questId], references: [id], onDelete: Cascade)
  questId String

  completedAt   DateTime @default(now())
  pointsAwarded Int      @default(0) @db.SmallInt

  isApproved Boolean   @default(true)
  approvedBy String?
  approvedAt DateTime?

  @@unique([userId, questId])
  @@index([userId])
  @@index([questId])
}

// ==========================================
// 2. THE ARENA (The "Game" Layer)
// ==========================================

model Game {
  id         String @id @default(cuid())
  gameNumber Int // Human-readable: WAFFLES #001, scoped per network

  // -- ON-CHAIN IDENTITY (random bytes32, stored as 0x-prefixed hex string) --
  onchainId String? @unique @db.VarChar(66)

  // -- INFO --
  platform    UserPlatform
  network     GameNetwork
  title       String    @db.VarChar(100)
  description String?   @db.VarChar(1000)
  theme       GameTheme
  coverUrl    String?   @db.VarChar(255)
  launchGroupId String? @db.VarChar(36)

  // -- TIMING (source of truth for game phase) --
  startsAt      DateTime
  endsAt        DateTime
  ticketsOpenAt DateTime? // When tickets become available (null = open immediately on create)

  // -- TICKET OPEN NOTIFICATION TRACKING --
  ticketOpenNotifsSent String[] @default([]) // Milestones already sent: "3h","1h","30m","15m","5m"

  // -- PRICING (flat $1 ticket) --
  tierPrices Float[] @default([1])

  // -- PRE-COMPUTED STATS (updated atomically) --
  prizePool   Float @default(0) // Sum of ticket prices
  playerCount Int   @default(0) // Count of entries

  // -- CONFIGURATION --
  roundBreakSec Int @default(20) @db.SmallInt
  maxPlayers    Int @default(200) @db.SmallInt

  // -- NETWORK --
  isTestnet Boolean @default(false) // Whether game was created on testnet

  // -- GAME LIFECYCLE TIMESTAMPS --
  rankedAt      DateTime? // When ranks/prizes were calculated (Step 1)
  onChainAt     DateTime? // When merkle root was published on-chain (Step 2)
  onChainTxHash String?   @db.VarChar(66) // TX that submitted merkle root

  // -- MERKLE DATA (for on-chain claims) --
  merkleRoot String? @db.VarChar(66) // 0x-prefixed, 32 bytes

  // -- RELATIONS --
  questions Question[]
  entries   GameEntry[]
  pendingPurchases PendingPurchase[]

  // -- TIMESTAMPS --
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // -- INDEXES --
  @@unique([launchGroupId, platform])
  @@unique([network, gameNumber])
  @@index([platform, startsAt])
  @@index([platform, endsAt])
  @@index([startsAt])
  @@index([endsAt])
}

enum GameTheme {
  FOOTBALL
  MOVIES
  ANIME
  POLITICS
  CRYPTO
  GENERAL
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// NOTE: GameStatus enum REMOVED
// Phase is now derived from startsAt/endsAt:
// - now < startsAt => SCHEDULED
// - startsAt <= now < endsAt => LIVE
// - now >= endsAt => ENDED

// ==========================================
// 2.5 QUESTION BANK (Reusable Templates)
// ==========================================

model QuestionTemplate {
  id String @id @default(cuid())

  // -- CONTENT --
  content      String   @db.VarChar(1000)
  options      String[]
  correctIndex Int      @db.SmallInt
  durationSec  Int      @default(10) @db.SmallInt

  // -- FORMAT (v2 multi-format support) --
  kind         QuestionKind @default(SINGLE)
  correctSet   Int[]        @default([])
  pick         Int?         @db.SmallInt
  correctOrder Int[]        @default([])
  flags        String[]     @default([])
  minefield    Boolean      @default(false)
  kicker       String?      @db.VarChar(120)
  clues        String[]     @default([])
  mediaUrl     String?  @db.VarChar(255)
  soundUrl     String?  @db.VarChar(255)

  // -- CATEGORIZATION --
  // `theme` is the coarse 6-value bucket (FOOTBALL vs general etc.) used by
  // themed games; `category` is the finer authoring category from the question
  // bank ("History", "Science", "Music", …) preserved verbatim so granularity
  // isn't lost. Stored as text (not an enum) to avoid migrations when the bank
  // adds categories.
  theme      GameTheme  @default(GENERAL)
  category   String?    @db.VarChar(40)
  difficulty Difficulty @default(MEDIUM)

  // -- TRACKING (denormalized for fast display) --
  usageCount Int @default(0)

  // -- TIMESTAMPS --
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // -- INDEXES --
  @@index([theme, difficulty])
  @@index([category])
  @@index([createdAt(sort: Desc)])
  @@index([usageCount(sort: Desc)])
}

model Question {
  id     String @id @default(cuid())
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId String

  // -- ORDERING --
  roundIndex   Int @default(1) @db.SmallInt
  orderInRound Int @default(0) @db.SmallInt

  // -- CONTENT --
  content      String   @db.VarChar(1000)
  mediaUrl     String?  @db.VarChar(255)
  soundUrl     String?  @db.VarChar(255)
  options      String[] // Native Postgres array
  correctIndex Int      @db.SmallInt

  // -- FORMAT (v2 multi-format support; SINGLE = classic one-of-four) --
  kind         QuestionKind @default(SINGLE)
  correctSet   Int[]        @default([])
  pick         Int?         @db.SmallInt
  correctOrder Int[]        @default([])
  flags        String[]     @default([])
  minefield    Boolean      @default(false)
  kicker       String?      @db.VarChar(120)
  clues        String[]     @default([])

  // -- TIMING & SCORING --
  durationSec Int @default(10) @db.SmallInt
  points      Int @default(100) @db.SmallInt

  // -- TEMPLATE ORIGIN (for tracking, nullable) --
  templateId String?

  // -- TIMESTAMPS --
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId, roundIndex, orderInRound])
  @@index([templateId])
}

// ==========================================
// 3. GAME ENTRY (Consolidates Ticket + GamePlayer)
// ==========================================
// Single record per user per game: payment + progress + results

model GameEntry {
  id String @id @default(cuid())

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  // -- PAYMENT --
  txHash      String?   @unique @db.VarChar(66)
  payerWallet String?   @db.VarChar(42) // Wallet address used for this purchase
  paidAmount  Float? // Tier price paid
  paidAt      DateTime?
  purchaseSource TicketPurchaseSource @default(PAID)
  freeIssuedById String?
  freeIssueNote  String? @db.VarChar(255)

  // -- PROGRESS (updated per answer) --
  score    Int @default(0)
  answered Int @default(0) @db.SmallInt

  // -- ANSWERS (embedded JSON for speed) --
  // Format: { "questionId": { "selected": 0, "correct": true, "points": 100, "ms": 2340 } }
  answers Json @default("{}")

  // -- FINAL RESULTS (set when game ends) --
  rank      Int?      @db.SmallInt
  prize     Float?
  claimedAt DateTime?

  // -- MERKLE PROOF (set during settlement for winners, rank 1-3) --
  // Stored as JSON array of hex strings: ["0x...", "0x...", ...]
  merkleProof  Json?
  merkleAmount String? @db.VarChar(78) // Prize amount in token units (bigint as string)

  // -- FORFEIT (set if user leaves during live game) --
  leftAt DateTime?

  // -- TIMESTAMPS --
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, userId])
  @@index([gameId, score(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([gameId, purchaseSource])
}

enum TicketPurchaseSource {
  PAID
  DISCOUNTED
  FREE_ADMIN
  FREE_PLAYER
}

// ==========================================
// 4. CHAT (Persisted messages)
// ==========================================

model PendingPurchase {
  id             String                @id @default(cuid())
  txHash         String                @unique @db.VarChar(66)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  game           Game                  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId         String
  platform       UserPlatform
  payerWallet    String                @db.VarChar(42)
  expectedAmount Float
  status         PendingPurchaseStatus @default(SUBMITTED)
  attempts       Int                   @default(0)
  lastError      String?               @db.VarChar(500)
  syncedEntryId  String?
  syncedAt       DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([status, updatedAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([gameId, createdAt(sort: Desc)])
}

// ==========================================
// 5. NOTIFICATIONS
// ==========================================
model NotificationToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  appFid    Int
  token     String   @db.VarChar(255)
  url       String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, appFid])
  @@index([token])
}

model NotificationLog {
  id        String   @id @default(cuid())
  channel   String   @db.VarChar(20)  // "batch" | "single"
  title     String   @db.VarChar(100)
  body      String   @db.VarChar(500)
  targetUrl String   @db.VarChar(1024)

  // Audience
  recipientCount Int // How many users were targeted
  userId         String? // For single-user sends

  // Results
  success       Int @default(0)
  failed        Int @default(0)
  invalidTokens Int @default(0)
  rateLimited   Int @default(0)
  durationMs    Int @default(0)

  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ==========================================
// 6. ADMIN AUDIT LOG
// ==========================================

model AuditLog {
  id      String @id @default(cuid())
  admin   User   @relation(fields: [adminId], references: [id])
  adminId String

  action     String   @db.VarChar(50)
  entityType String   @db.VarChar(50)
  entityId   String?  @db.VarChar(50)
  details    Json?
  ip         String?  @db.VarChar(45)
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([entityType, entityId])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  name       String   @db.VarChar(100)
  userId     String?
  source     String   @default("server") @db.VarChar(20)
  properties Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ==========================================
// 7. ADMIN INVITE CODES (One-Time Use)
// ==========================================

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique @db.VarChar(6)
  usedById  String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  note      String?   @db.VarChar(100)

  usedBy User? @relation(fields: [usedById], references: [id])

  @@index([code])
}

// ==========================================
// 8. V2 MIGRATION — PROGRESSION, ECONOMY & CONTENT
// Backs the ported v2 screens (see docs/v2-migration.md). The `Proto` interface
// in src/app/v2/_app/state.tsx is the contract these satisfy.
// ==========================================

enum QuestionKind {
  SINGLE
  MULTI
  ORDER
  SPATIAL
}

enum LevelTrack {
  STANDARD
  WORLD_CUP
}

enum TicketLedgerReason {
  LEVEL_MILESTONE
  TOURNAMENT_REWARD
  TOURNAMENT_ENTRY
  DAILY_REWARD
  SHOP_PURCHASE
  BUNDLE_TOPUP
  LIVES_REFILL
  WINNING_CONVERT
  FIRST_TICKET_OFFER
  PARTNER_OFFER
  SEASON_PASS
  LEAGUE_REWARD
  ADMIN_ADJUST
}


enum ShopItemKind {
  POWERUP
  COSMETIC
  BUNDLE
  BOOST
  FEATURED
}

enum PowerUpKind {
  FIFTY_FIFTY
  EXTRA_TIME
  SKIP
  SHIELD
}

enum BoostKind {
  DOUBLE_XP
}

enum CosmeticKind {
  AVATAR_FRAME
  NAME_COLOR
  EMOTE
}

enum LeagueTier {
  APPRENTICE_1
  APPRENTICE_2
  SILVER_1
  SILVER_2
  SILVER_3
  ADVANCED_1
  ADVANCED_2
  GENIUS
  MASTER_3
  MASTER_2
  MASTER_1
}

// Season-close outcome for a LeagueMember (top finishers move up, bottom move down).
enum LeagueOutcome {
  PROMOTED
  DEMOTED
  STAYED
}

// -- Soft-currency ledger: every ticket balance change is recorded here; the
//    denormalized running total lives on User.ticketBalance. --
model TicketLedger {
  id           String             @id @default(cuid())
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  delta        Int
  balanceAfter Int
  reason       TicketLedgerReason
  refId        String?            @db.VarChar(60)
  note         String?            @db.VarChar(255)
  createdAt    DateTime           @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// -- Solo level campaign: independent progression per track. --
model LevelProgress {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  track     LevelTrack
  level     Int        @default(1) @db.SmallInt
  updatedAt DateTime   @updatedAt

  @@unique([userId, track])
}

// -- Hourly tournament round entry. roundId = epoch-ms bucket of the round
//    window. Provisional until settled (rank/reward lock at close). --
model RoundEntry {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  roundId      BigInt
  score        Int?
  bonus        Boolean   @default(false)
  settled      Boolean   @default(false)
  finalRank    Int?
  reward       Int? // tickets
  resultReadAt DateTime?
  createdAt    DateTime  @default(now())
  settledAt    DateTime?

  @@unique([userId, roundId])
  @@index([roundId, score(sort: Desc)])
}

// -- In-app announcements + per-user read/dismiss state. --
model Announcement {
  id        String              @id @default(cuid())
  slug      String              @unique @db.VarChar(60)
  title     String              @db.VarChar(140)
  body      String              @db.VarChar(1000)
  ctaLabel  String?             @db.VarChar(60)
  // CTA routing target, encoded as "screen:<name>" or "theme:<id>" (parsed client-side).
  ctaAction String?             @db.VarChar(120)
  kind      String              @default("info") @db.VarChar(30)
  // Display tone (banner/inbox accent): "maple" | "berry" | "leaf".
  tone      String              @default("leaf") @db.VarChar(12)
  // Leading emoji shown on the banner/inbox card.
  emoji     String              @default("📣") @db.VarChar(8)
  isActive  Boolean             @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  sortOrder Int                 @default(0) @db.SmallInt
  createdAt DateTime            @default(now())
  states    AnnouncementState[]
}

model AnnouncementState {
  id             String       @id @default(cuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String
  readAt         DateTime?
  dismissedAt    DateTime?

  @@unique([userId, announcementId])
}

// -- Per-user mission progress (counts toward Quest.requiredCount). --
model QuestProgress {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  questId   String
  count     Int      @default(0) @db.SmallInt
  updatedAt DateTime @updatedAt

  @@unique([userId, questId])
}

// -- Leagues: tier definitions (with reward ladder config) + per-user, per-season
//    membership/standing. --
model League {
  id        String         @id @default(cuid())
  tier      LeagueTier     @unique
  label     String         @db.VarChar(40)
  color     String         @db.VarChar(9)
  sortOrder Int            @db.SmallInt
  rewards   Json
  members   LeagueMember[]
  cohorts   LeagueCohort[]
}

// A room of (up to ~30) players competing within one tier for one season.
// Ranking, promotion/demotion and reward payout all happen per cohort.
model LeagueCohort {
  id        String         @id @default(cuid())
  league    League         @relation(fields: [leagueId], references: [id])
  leagueId  String
  season    String         @db.VarChar(20)
  index     Int            @db.SmallInt // 0-based cohort number within tier+season
  settledAt DateTime? // set when the season-close job has paid + promoted this cohort
  members   LeagueMember[]

  @@unique([leagueId, season, index])
  @@index([season, settledAt])
}

model LeagueMember {
  id        String         @id @default(cuid())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  league    League         @relation(fields: [leagueId], references: [id])
  leagueId  String
  cohort    LeagueCohort?  @relation(fields: [cohortId], references: [id])
  cohortId  String?
  season    String         @db.VarChar(20)
  points    Int            @default(0)
  rank      Int?
  outcome   LeagueOutcome? // set at season close
  updatedAt DateTime       @updatedAt

  @@unique([userId, season])
  @@index([season, points(sort: Desc)])
  @@index([cohortId, points(sort: Desc)])
}

// -- Shop catalog + purchases (power-ups, cosmetics, bundles, boosts, featured). --
model ShopItem {
  id           String       @id @default(cuid())
  slug         String       @unique @db.VarChar(60)
  kind         ShopItemKind
  label        String       @db.VarChar(60)
  sub          String?      @db.VarChar(120)
  priceTickets Int?
  priceFiat    Float?
  payload      Json? // kind-specific config (powerup kind, bundle counts, boost charges…)
  color        String?      @db.VarChar(9)
  iconUrl      String?      @db.VarChar(255)
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0) @db.SmallInt
  purchases    Purchase[]
}

model Purchase {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  item         ShopItem @relation(fields: [itemId], references: [id])
  itemId       String
  qty          Int      @default(1) @db.SmallInt
  spentTickets Int      @default(0)
  spentFiat    Float?
  txHash       String?  @db.VarChar(66)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model PowerUpInventory {
  id     String      @id @default(cuid())
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  kind   PowerUpKind
  count  Int         @default(0) @db.SmallInt

  @@unique([userId, kind])
}

model UserCosmetic {
  id         String       @id @default(cuid())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  slug       String       @db.VarChar(60)
  kind       CosmeticKind
  equipped   Boolean      @default(false)
  acquiredAt DateTime     @default(now())

  @@unique([userId, slug])
}

model UserBoost {
  id               String    @id @default(cuid())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  kind             BoostKind
  remainingCharges Int?      @db.SmallInt
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
}

// -- Badge unlocks. Badge definitions stay in code (derived from stats); this
//    persists the earned moment for the unlock celebration. --
model UserBadge {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  badgeId  String   @db.VarChar(60)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

// -- Sponsored partner offers (Missions → Partners tab). Definitions are catalog
//    rows; per-user, one-time completion credits the offer's ticket reward. --
model PartnerOffer {
  id         String              @id @default(cuid())
  slug       String              @unique @db.VarChar(60)
  brand      String              @db.VarChar(60)
  brandColor String              @db.VarChar(9)
  glyph      String              @db.VarChar(8)
  title      String              @db.VarChar(140)
  cta        String              @db.VarChar(40)
  tickets    Int                 @db.SmallInt
  estTime    String              @db.VarChar(20)
  verified   Boolean             @default(true)
  hot        Boolean             @default(false)
  isActive   Boolean             @default(true)
  sortOrder  Int                 @default(0) @db.SmallInt
  claims     PartnerOfferClaim[]
}

model PartnerOfferClaim {
  id        String       @id @default(cuid())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  offer     PartnerOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId   String
  tickets   Int          @default(0) @db.SmallInt
  createdAt DateTime     @default(now())

  @@unique([userId, offerId])
}

// -- Season Pass: per-user, per-season record of claimed reward cells. Tier
//    definitions + reward amounts live in code (src/lib/v2/seasonPass.ts);
//    pass level/progress derive from XP. One row per claimed (tier, premium). --
model SeasonPassClaim {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  season    String   @db.VarChar(20)
  tier      Int      @db.SmallInt
  premium   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, season, tier, premium])
}

// -- Daily reward: one claim per calendar day; stores the weighted-random roll. --
model DailyRewardClaim {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  dayKey     String   @db.VarChar(10) // YYYY-MM-DD
  streak     Int      @default(1) @db.SmallInt
  reward     Json // rolled prize { kind, amount }
  usedFreeze Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, dayKey])
}
