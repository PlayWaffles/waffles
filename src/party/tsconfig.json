{
  // The party server runs in the Cloudflare Workers runtime, not Next.js, so it
  // gets its own tsconfig with Workers types. The root tsconfig excludes this
  // folder (see its "exclude"), keeping Worker globals out of the app typecheck.
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "include": ["server.ts"]
}
